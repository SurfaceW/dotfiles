# Folder view configuration files
.DS_Store
Desktop.ini

# Thumbnail cache files
._*
Thumbs.db

# Files that might appear on external disks
.Spotlight-V100
.Trashes

# Compiled Python files
*.pyc

# Compiled C++ files
*.out

# Application specific files
venv
node_modules
.sass-cache

# Machine-local overrides (managed by dotfiles-keeper)
*.local
.gitconfig.local
.zshrc.local

# Secrets — never commit
.secrets/
*.env
!*.env.example

# Backups created by install.sh
*.bak.*